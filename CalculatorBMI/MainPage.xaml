<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="revestodolist.MainPage"
             BackgroundColor="#F2F2F2">

    <VerticalStackLayout Spacing="10" Padding="10">

        <!-- Input Section -->
        <VerticalStackLayout Padding="10"
                             Spacing="10"
                             BackgroundColor="White"
                             Margin="0,0,0,10">

            <Entry x:Name="titleEntry"
                   Placeholder="Title"
                   MaxLength="50"/>

            <Editor x:Name="detailsEditor"
                    Placeholder="Details"
                    MaxLength="240"
                    HeightRequest="100"/>

            <Button x:Name="addBtn"
                    Text="Add"
                    BackgroundColor="LightBlue"
                    Clicked="AddToDoItem"/>

            <Button x:Name="editBtn"
                    Text="Save Edit"
                    IsVisible="False"
                    BackgroundColor="LightGray"
                    Clicked="EditToDoItem"/>

            <Button x:Name="cancelBtn"
                    Text="Cancel Edit"
                    IsVisible="False"
                    BackgroundColor="LightCoral"
                    Clicked="CancelEdit"/>

        </VerticalStackLayout>

        <!-- ListView Section -->
        <ListView x:Name="todoLV"
                  HasUnevenRows="True"
                  ItemSelected="TodoLV_OnItemSelected">

            <ListView.ItemTemplate>
                <DataTemplate>
                    <ViewCell>
                        <Grid Margin="10"
                              RowSpacing="5">

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="8*"/>
                                <ColumnDefinition Width="2*"/>
                            </Grid.ColumnDefinitions>

                            <Label Grid.Row="0"
                                   Grid.Column="0"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   Text="{Binding title}" />

                            <Label Grid.Row="1"
                                   Grid.Column="0"
                                   FontSize="14"
                                   Text="{Binding detail}" />

                            <Button Text="Delete"
                                    BackgroundColor="LightCoral"
                                    ClassId="{Binding id}"
                                    Grid.Row="0"
                                    Grid.RowSpan="2"
                                    Grid.Column="1"
                                    Clicked="DeleteToDoItem"/>

                        </Grid>
                    </ViewCell>
                </DataTemplate>
            </ListView.ItemTemplate>

        </ListView>

    </VerticalStackLayout>
</ContentPage>
